from vpython import sphere, color, scene, vector
import math

# გარშემოწირულობა კმ
circumference_km = 300_000

# რადიუსი
radius_km = circumference_km / (2 * math.pi)

# შექმენი 3D ბურთი
ball = sphere(
    pos=vector(0,0,0),     # ცენტრი
    radius=radius_km,       # რადიუსი
    color=color.blue,       # ფერი
    opacity=0.5             # ნახევრად გამჭვირვალე
)

scene.title = "ბურთი გარშემოწირულობით 300,000 კმ"
scene.background = color.white
